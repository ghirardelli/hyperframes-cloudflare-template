{
  "$schema": "node_modules/wrangler/config-schema.json",
  
  "main": "src/server.ts",
  "compatibility_date": "2026-06-28",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  "name": "hyperframes-cloudflare-template",

  // AI generation. The OpenRouter key is configured server-side with:
  // wrangler secret put OPENROUTER_API_KEY
  // Public-demo deployers: flip ENABLE_AI_GEN to "false" so visitors can't
  // run the render container on your account from generated HTML.
  "vars": {
    "ENABLE_AI_GEN": "true",
    "ENABLE_WEBSITE_TO_VIDEO_WORKFLOW": "false",
    // Optional first-admin bootstrap. Remove after assigning real admin users:
    // "INITIAL_ADMIN_EMAILS": "admin@example.com"
    // Optional model override:
    // "OPENROUTER_MODEL": "google/gemini-3-flash-preview"
    "BUNNY_STORAGE_ZONE_NAME": "motionframes-projects-staging",
    "BUNNY_STORAGE_ENDPOINT": "https://la.storage.bunnycdn.com",
    "BUNNY_STREAM_LIBRARY_ID": "693756",
    "BUNNY_STREAM_API_BASE": "https://video.bunnycdn.com",
    "BUNNY_STREAM_COLLECTION_ID": "739591c5-cc47-4647-a270-4fdb3f9e54b5"
  },

  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },

  // After creating a Cloudflare Hyperdrive config for the Neon database, add:
  // "hyperdrive": [
  //   {
  //     "binding": "HYPERDRIVE",
  //     "id": "<YOUR_HYPERDRIVE_ID>",
  //     "localConnectionString": "postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"
  //   }
  // ],

  "containers": [
    {
      "name": "hyperframes-on-cloudflare-rendercontainer",
      "class_name": "RenderContainer",
      "image": "./Dockerfile",
      "max_instances": 5,
      "instance_type": "standard-4"
    },
    {
      "name": "hyperframes-on-cloudflare-workflowcontainer",
      "class_name": "WorkflowContainer",
      "image": "./Dockerfile",
      "max_instances": 2,
      "instance_type": "standard-1"
    }
  ],

  "durable_objects": {
    "bindings": [
      { "name": "RENDER_CONTAINER", "class_name": "RenderContainer" },
      { "name": "WORKFLOW_CONTAINER", "class_name": "WorkflowContainer" }
    ]
  },

  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["RenderContainer"] },
    { "tag": "v2", "new_sqlite_classes": ["WorkflowContainer"] }
  ],

  "r2_buckets": [
    { "binding": "RENDERS", "bucket_name": "motion-frames-renders" }
  ]
}
