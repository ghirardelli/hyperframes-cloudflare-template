# Local-only secrets. Copy to .dev.vars and fill in.
# Production secrets go in Cloudflare dashboard or `wrangler secret put`.
OPENROUTER_API_KEY=

# Optional. Defaults to the app's server-side model when omitted.
# OPENROUTER_MODEL=google/gemini-3-flash-preview

# Optional prompt-agent voice input. Required for browser recordings to be
# transcribed server-side; omit to keep the microphone UI disabled.
# OPENAI_API_KEY=
# OPENAI_TRANSCRIPTION_MODEL=whisper-1

DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
BETTER_AUTH_URL="http://localhost:5173"

# Better Auth Dash ownership verification / infrastructure plugin.
# API/KV URLs default to Better Auth's hosted services when omitted.
# Add the Dash API key if Better Auth provides one for your project.
# BETTER_AUTH_API_URL="https://dash.better-auth.com"
# BETTER_AUTH_KV_URL="https://kv.better-auth.com"
# BETTER_AUTH_API_KEY=""

# Optional. Comma-separated additional origins allowed by Better Auth.
# The hosted Better Auth Dash origin is trusted by the app automatically.
# BETTER_AUTH_TRUSTED_ORIGINS="https://app.example.com"

# Optional bootstrap: comma-separated emails that should be treated as admins
# even before a Motion Frames membership exists. Create or seed the matching
# Better Auth user first, then remove this after assigning a real admin user.
INITIAL_ADMIN_EMAILS="admin@example.com"
