{
  "name": "motion-frames",
  "description": "TanStack Start app for generating, previewing, and rendering HyperFrames video compositions on Cloudflare.",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "cloudflare": {
    "label": "Motion Frames",
    "products": [
      "Workers",
      "Containers",
      "R2",
      "Hyperdrive"
    ],
    "categories": [],
    "docs_url": "https://github.com/heygen-com/hyperframes",
    "preview_image_url": "",
    "icon_urls": [],
    "bindings": {
      "RENDER_CONTAINER": {
        "description": "Container Durable Object hosting Chromium + ffmpeg + hyperframes; receives composition files and returns MP4 bytes."
      },
      "RENDERS": {
        "description": "R2 bucket where rendered MP4s are stored. Created automatically on first deploy."
      },
      "ASSETS": {
        "description": "Static asset binding for the preview UI and the bundled composition HTML."
      }
    }
  },
  "scripts": {
    "predev": "node scripts/build.mjs",
    "dev": "vite dev",
    "prebuild": "node scripts/build.mjs",
    "build": "vite build",
    "deploy": "npm run build && wrangler deploy --config dist/server/wrangler.json",
    "deploy:dry-run": "npm run build && wrangler deploy --config dist/server/wrangler.json --dry-run",
    "test": "vitest run --config vitest.config.ts",
    "test:secret-ui": "node scripts/verify-secret-ui.mjs",
    "sync:hyperframes-skills": "node scripts/sync-hyperframes-skills.mjs",
    "check:hyperframes-skills": "node scripts/sync-hyperframes-skills.mjs --check",
    "sync:hyperframe-gallery": "node scripts/sync-hyperframe-gallery-catalog.mjs",
    "check:hyperframe-gallery": "node scripts/sync-hyperframe-gallery-catalog.mjs --check",
    "sync:hyperframe-components": "node scripts/sync-hyperframe-component-registry.mjs",
    "check:hyperframe-components": "node scripts/sync-hyperframe-component-registry.mjs --check",
    "pretypecheck": "wrangler types",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:reindex-projects": "node scripts/reindex-project-entries.mjs",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@better-auth/infra": "^0.3.4",
    "@cloudflare/containers": "^0.0.20",
    "@hyperframes/core": "^0.7.21",
    "@hyperframes/player": "^0.7.21",
    "@hyperframes/studio": "^0.7.21",
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@tanstack/ai": "^0.38.0",
    "@tanstack/ai-client": "^0.19.0",
    "@tanstack/ai-openai": "^0.15.9",
    "@tanstack/ai-openrouter": "^0.15.4",
    "@tanstack/ai-react": "^0.16.0",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-start": "^1.168.26",
    "better-auth": "^1.6.22",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.3",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/router-plugin": "^1.168.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "shadcn": "4.11.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  },
  "overrides": {
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.12"
    }
  },
  "engines": {
    "node": ">=22"
  }
}
